qmake: FORCE
	@$(QMAKE) -o Makefile ..\..\Pharmacy_Management_System.pro -spec win32-g++ "CONFIG+=debug" "CONFIG+=qml_debug"

qmake_all: sub-AdminClient-qmake_all sub-CustomerClient-qmake_all sub-PharmacyServer-qmake_all sub-StaffClient-qmake_all FORCE

make_first: sub-AdminClient-make_first sub-CustomerClient-make_first sub-PharmacyServer-make_first sub-StaffClient-make_first  FORCE
all: sub-AdminClient-all sub-CustomerClient-all sub-PharmacyServer-all sub-StaffClient-all  FORCE
clean: sub-AdminClient-clean sub-CustomerClient-clean sub-PharmacyServer-clean sub-StaffClient-clean  FORCE
distclean: sub-AdminClient-distclean sub-CustomerClient-distclean sub-PharmacyServer-distclean sub-StaffClient-distclean  FORCE
	-$(DEL_FILE) Makefile
	-$(DEL_FILE) .qmake.stash
install_subtargets: sub-AdminClient-install_subtargets sub-CustomerClient-install_subtargets sub-PharmacyServer-install_subtargets sub-StaffClient-install_subtargets FORCE
uninstall_subtargets: sub-AdminClient-uninstall_subtargets sub-CustomerClient-uninstall_subtargets sub-PharmacyServer-uninstall_subtargets sub-StaffClient-uninstall_subtargets FORCE

sub-AdminClient-debug:
	@if not exist AdminClient\ mkdir AdminClient\ & if not exist AdminClient\ exit 1
	cd AdminClient\ && ( if not exist Makefile $(QMAKE) -o Makefile D:\Qt_Projects\Pharmacy_Management_System\AdminClient\AdminClient.pro -spec win32-g++ "CONFIG+=debug" "CONFIG+=qml_debug" ) && $(MAKE) -f Makefile debug
