   <string notr="true">/* Fundalul ferestrei */
QDialog {
    background-color: #f8f9fa;
}

/* Stil pentru campurile de text */
QLineEdit {
    padding: 10px;
    border: 1px solid #ced4da;
    border-radius: 6px;
    background-color: white;
    font-size: 14px;
    margin-bottom: 10px;
}

QLineEdit:focus {
    border: 2px solid #2ecc71; /* Verdele tau de la Admin */
}

/* Butonul de Login */
QPushButton#btnLogin {
    background-color: #2ecc71;
    color: white;
    border-radius: 6px;
    font-weight: bold;
    padding: 12px;
    font-size: 14px;
}

QPushButton#btnLogin:hover {
    background-color: #27ae60;
}

/* Mesajul de eroare sub buton */
QLabel#lblError {
    color: #e74c3c;
    font-size: 12px;
    font-weight: bold;
}</string>
